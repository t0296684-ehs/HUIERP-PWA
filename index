  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${apiKey}`;
  
  const response = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      contents: [{
        parts: [
          { text: prompt },
          {
            inline_data: {
              mime_type: 'image/jpeg',
              data: base64Image
            }
          }
        ]
      }],
      generationConfig: {
        temperature: 0.1,
        maxOutputTokens: 1024
      }
    })
  });
  
  if (!response.ok) {
    const err = await response.text();
    throw new Error(`Gemini 辨識失敗: ${response.status} - ${err.slice(0, 100)}`);
  }
  
  const data = await response.json();
  const text = data.candidates?.[0]?.content?.parts?.[0]?.text || '';
  
  // 清掉可能的 markdown 框
  const cleaned = text.replace(/```json\s*/g, '').replace(/```\s*$/g, '').trim();
  
  try {
    return JSON.parse(cleaned);
  } catch (e) {
    throw new Error('辨識結果無法解析,請重拍清楚一點');
  }
}

// 寫入 Google Sheets (透過 Apps Script Webhook)
async function writeToSheets(data, webhookUrl, webhookKey) {
  const response = await fetch(webhookUrl, {
    method: 'POST',
    headers: { 'Content-Type': 'text/plain;charset=utf-8' },
    body: JSON.stringify({
      apiKey: webhookKey,
      data: data
    })
  });
  
  if (!response.ok) {
    throw new Error(`寫入 Sheets 失敗: ${response.status}`);
  }
  
  const result = await response.json();
  if (!result.success) {
    throw new Error(result.error || '寫入失敗');
  }
  
  return result;
}

// 顯示完成 (給阿輝師看辨識到什麼)
function showDone(data) {
  const detail = document.getElementById('doneDetail');
  const fields = [
    ['👤 客戶', data['客戶姓名']],
    ['📞 電話', data['聯絡電話']],
    ['🪵 木種', data['木種']],
    ['🖌️ 款式', data['款式']],
    ['🔢 數量', data['數量']],
    ['💰 單價', data['單價']],
    ['🎨 噴漆', data['噴漆種類']],
    ['📅 交期', data['預計交期']]
  ];
  
  detail.innerHTML = fields
    .filter(([, v]) => v)
    .map(([k, v]) => `<div><strong>${k}:</strong> ${v}</div>`)
    .join('');
  
  if (!detail.innerHTML) {
    detail.innerHTML = '<div style="color:#D97706">⚠️ 辨識結果有點少,請到電腦上的 Google Sheets 確認</div>';
  }
  
  showState('done');
}

